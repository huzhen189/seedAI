# 环境变量模板(可提交到版本库,不含任何真实密钥)
# 复制为 .env 后填入真实值

# 模型 Key(核心 AI 服务)
DEEPSEEK_API_KEY=
QWEN_API_KEY=
QWEN_API_HOST=
QWEN_BASE_URL=
QWEN_DASHSCOPE_URL=
HY3_API_KEY=
HY3_BASE_URL=

# 服务配置
BUSINESS_API_PORT=7101
AI_SERVICE_PORT=7102
AI_SERVICE_URL=http://ai-service:7102

JWT_SECRET=change-me-in-production
# Cookie 鉴权:生产设 true(仅 HTTPS 下发);本地 http 开发设 false 才能写入
COOKIE_SECURE=false

DATABASE_URL=mysql+aiomysql://seedai:seedai@mysql:3306/seedai
REDIS_URL=redis://redis:6379/0
CHROMA_URL=http://chroma:8000

# ---- AI 服务 · 向量检索 / 记忆(§7) ----
QWEN_EMBEDDING_KEY=
QWEN_EMBEDDING_MODEL=text-embedding-v3
RAG_TOP_K=5
CHROMA_COLLECTION_COMPONENTS=components
CHROMA_COLLECTION_MEMORY=memory
CHROMA_COLLECTION_CACHE=cache_gen

# ---- AI 服务 · 对象存储 COS 预览投递(§10 / §5.9 tool:cos_upload) ----
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=seedhtml-1252059540
COS_REGION=ap-guangzhou
COS_PREVIEW_DOMAIN=https://seedhtml-1252059540.cos.ap-guangzhou.myqcloud.com
COS_BASE_PATH=previews
COS_TTL_DAYS=0

# ---- AI 服务 · 检索/搜索工具(§5.9 tool:web_search / image_generate) ----
TAVILY_API_KEY=
SERPER_API_KEY=
WEB_SEARCH_TOP_K=5
ARTIFACT_DIR=./artifacts
IMAGE_API_KEY=
IMAGE_API_BASE=
IMAGE_MODEL=dall-e-3
